rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================================
    // FUNÇÕES AUXILIARES
    // =========================================================================
    
    // Verifica se o usuário está logado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica se o ID do usuário logado é igual ao ID fornecido (dono do dado)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // =========================================================================
    // REGRAS DAS COLEÇÕES
    // =========================================================================

    // Regras para Usuários (users)
    // Usado no Perfil e Ranking
    match /users/{userId} {
      // PERMITIR LEITURA: Qualquer usuário logado pode ler (para ver o Ranking)
      allow read: if isAuthenticated();
      
      // PERMITIR ESCRITA: Apenas o próprio dono da conta pode editar seus dados
      allow write: if isOwner(userId);
    }

    // Regras para Grupos/Desafios (groups)
    match /groups/{groupId} {
      // PERMITIR LEITURA: Qualquer usuário logado pode ler (para preview de convite)
      allow read: if isAuthenticated();
      
      // PERMITIR CRIAÇÃO: Qualquer usuário logado pode criar
      allow create: if isAuthenticated();
      
      // PERMITIR ATUALIZAÇÃO:
      allow update: if isAuthenticated() && (
        // Membros existentes podem atualizar (ex: sair do grupo, alterações gerais)
        request.auth.uid in resource.data.memberIds ||
        // Ou: usuário não-membro está SE adicionando ao grupo (join via código de convite)
        // — só pode alterar 'memberIds' e 'memberCount', nada mais
        (
          !(request.auth.uid in resource.data.memberIds) &&
          request.auth.uid in request.resource.data.memberIds &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'memberCount'])
        )
      );
      
      // PERMITIR DELEÇÃO: Apenas o criador do grupo
      allow delete: if isAuthenticated() && 
        resource.data.createdBy == request.auth.uid;
    }

    // Regras para Check-ins (checkins)
    // Usado no Feed e Perfil
    match /checkins/{checkinId} {
      // PERMITIR LEITURA: Qualquer usuário logado pode ler (para ver o Feed)
      allow read: if isAuthenticated();
      
      // PERMITIR CRIAÇÃO:
      // 1. Usuário deve estar logado
      // 2. O campo 'userId' do novo documento deve ser igual ao ID do usuário logado
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // PERMITIR ATUALIZAÇÃO E DELEÇÃO:
      // Apenas o dono do check-in pode editar ou apagar
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Regras para Comentários (subcoleção de check-ins)
      match /comments/{commentId} {
        // PERMITIR LEITURA: Qualquer usuário logado pode ler comentários
        allow read: if isAuthenticated();
        
        // PERMITIR CRIAÇÃO: Usuário logado com seu próprio userId
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        
        // PERMITIR ATUALIZAÇÃO/DELEÇÃO: Apenas o dono do comentário
        allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      }
    }

    // Regras para Mensagens (messages)
    match /messages/{messageId} {
      // PERMITIR LEITURA: Qualquer usuário logado pode ler
      allow read: if isAuthenticated();
      
      // PERMITIR CRIAÇÃO: Usuário logado com seu próprio userId
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // PERMITIR ATUALIZAÇÃO/DELEÇÃO: Apenas o dono
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Regras para Typing Status (typing_status)
    match /typing_status/{statusId} {
      allow read, write: if isAuthenticated();
    }

    // Regras para Metadata do App (usado na migração)
    match /app_metadata/{docId} {
      allow read: if true; // Permiti leitura pública para verificar status de migração
      allow write: if isAuthenticated(); 
    }
  }
}
